{
  "AutomationLevel": 1,
  "Ollama": {
    "ApiUrl": "http://localhost:11434/api",
    "DefaultModel": "llama3",
    "TimeoutMs": 30000,
    "RetryCount": 3
  },
  "Monitor": {
    "CheckInterval": 30000,
    "CpuThreshold": 80,
    "MemoryThreshold": 85,
    "DiskThreshold": 90
  },
  "Whitelist": {
    "Processes": ["explorer", "chrome", "edge", "code"],
    "Directories": ["C:\\Windows", "C:\\Program Files"]
  },
  "Cleaner": {
    "TempFileThreshold": 7,
    "LogFileThreshold": 30,
    "AutoClean": false
  }
}