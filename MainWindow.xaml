<Window x:Class="AIPCAssistant.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AIPCAssistant.ViewModels"
        xmlns:local="clr-namespace:AIPCAssistant"
        Title="自由AIPC助手"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <local:ValueToColorConverter x:Key="ValueToColorConverter" />
        <Style TargetType="Button">
            <Setter Property="Background" Value="#0078D7" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center" 
                                              TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#004080" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E0E0E0" />
                                <Setter Property="Foreground" Value="#999999" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Rectangle Fill="#F2F2F7" />
                            <Thumb x:Name="PART_Track" Background="#0078D7" Opacity="0.5">
                                <Thumb.Style>
                                    <Style TargetType="Thumb">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Rectangle Fill="{TemplateBinding Background}" RadiusX="4" RadiusY="4" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#005A9E" />
                                                <Setter Property="Opacity" Value="0.8" />
                                            </Trigger>
                                            <Trigger Property="IsDragging" Value="True">
                                                <Setter Property="Background" Value="#004080" />
                                                <Setter Property="Opacity" Value="1" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Thumb.Style>
                            </Thumb>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#0078D7" Padding="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⚙️" FontSize="24" Foreground="White" />
                <TextBlock Text="自由AIPC助手" FontSize="18" FontWeight="Bold" Foreground="White" Margin="10,0,0,0" />
                <TextBlock Text=" - AI驱动的系统自治助手" FontSize="12" Foreground="#E0E0E0" Margin="10,4,0,0" />
            </StackPanel>
        </Border>
        
        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- 左侧导航 -->
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <StackPanel>
                    <Border Height="1" Background="#E0E0E0" />
                    <ListBox Margin="0" Background="Transparent" BorderThickness="0" SelectionMode="Single" SelectedValuePath="Tag" SelectedValue="{Binding SelectedNavItem, Mode=TwoWay}">
                        <ListBoxItem Content="系统健康" Tag="Health" IsSelected="True">
                            <ListBoxItem.Template>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="20" BorderThickness="0,0,3,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📊" Margin="0,0,10,0" />
                                            <TextBlock Text="{TemplateBinding Content}" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E6F7FF" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#0078D7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ListBoxItem.Template>
                        </ListBoxItem>
                        <ListBoxItem Content="优化工具" Tag="Tools">
                            <ListBoxItem.Template>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="20" BorderThickness="0,0,3,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🛠️" Margin="0,0,10,0" />
                                            <TextBlock Text="{TemplateBinding Content}" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E6F7FF" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#0078D7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ListBoxItem.Template>
                        </ListBoxItem>
                        <ListBoxItem Content="AI分析" Tag="AI">
                            <ListBoxItem.Template>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="20" BorderThickness="0,0,3,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🧠" Margin="0,0,10,0" />
                                            <TextBlock Text="{TemplateBinding Content}" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E6F7FF" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#0078D7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ListBoxItem.Template>
                        </ListBoxItem>
                        <ListBoxItem Content="操作历史" Tag="History">
                            <ListBoxItem.Template>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="20" BorderThickness="0,0,3,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📋" Margin="0,0,10,0" />
                                            <TextBlock Text="{TemplateBinding Content}" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E6F7FF" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#0078D7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ListBoxItem.Template>
                        </ListBoxItem>
                        <ListBoxItem Content="设置" Tag="Settings">
                            <ListBoxItem.Template>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="20" BorderThickness="0,0,3,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="⚙️" Margin="0,0,10,0" />
                                            <TextBlock Text="{TemplateBinding Content}" />
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#E6F7FF" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter TargetName="Border" Property="BorderBrush" Value="#0078D7" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ListBoxItem.Template>
                        </ListBoxItem>
                    </ListBox>
                </StackPanel>
            </Border>
            
            <!-- 右侧主内容区 -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <!-- 内容区域 -->
                <ScrollViewer Grid.Row="0" Margin="20" VerticalScrollBarVisibility="Auto">
                    <ContentControl Content="{Binding}">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- 系统健康状态卡片 -->
                                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,20" Padding="20" Visibility="{Binding SelectedNavItem, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Health}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                                                <TextBlock Text="📊" FontSize="24" />
                                                <TextBlock Text="系统健康状态" FontSize="18" FontWeight="Bold" Margin="10,0,0,0" />
                                            </StackPanel>
                                            
                                            <!-- 系统性能指标 -->
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="80" />
                                                    <RowDefinition Height="80" />
                                                    <RowDefinition Height="80" />
                                                </Grid.RowDefinitions>
                                                
                                                <!-- CPU 使用率 -->
                                                <Border Grid.Row="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Padding="15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                            <TextBlock Text="🔄" FontSize="16" />
                                                            <TextBlock Text="CPU 使用率" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" />
                                                            <TextBlock Text="{Binding CpuUsage, StringFormat={}{0:F1}%}" FontSize="14" FontWeight="Bold" Margin="10,0,0,0" Foreground="{Binding CpuUsage, Converter={StaticResource ValueToColorConverter}}" />
                                                        </StackPanel>
                                                        <ProgressBar Value="{Binding CpuUsage}" Maximum="100" Height="10" Margin="30,10,0,0" Foreground="{Binding CpuUsage, Converter={StaticResource ValueToColorConverter}}" Background="#F2F2F7" />
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- 内存使用率 -->
                                                <Border Grid.Row="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Padding="15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                            <TextBlock Text="💾" FontSize="16" />
                                                            <TextBlock Text="内存使用率" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" />
                                                            <TextBlock Text="{Binding MemoryUsage, StringFormat={}{0:F1}%}" FontSize="14" FontWeight="Bold" Margin="10,0,0,0" Foreground="{Binding MemoryUsage, Converter={StaticResource ValueToColorConverter}}" />
                                                        </StackPanel>
                                                        <ProgressBar Value="{Binding MemoryUsage}" Maximum="100" Height="10" Margin="30,10,0,0" Foreground="{Binding MemoryUsage, Converter={StaticResource ValueToColorConverter}}" Background="#F2F2F7" />
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- 磁盘使用率 -->
                                                <Border Grid.Row="2" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Padding="15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                            <TextBlock Text="💽" FontSize="16" />
                                                            <TextBlock Text="磁盘使用率 (C:)" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" />
                                                            <TextBlock Text="{Binding DiskUsage, StringFormat={}{0:F1}%}" FontSize="14" FontWeight="Bold" Margin="10,0,0,0" Foreground="{Binding DiskUsage, Converter={StaticResource ValueToColorConverter}}" />
                                                        </StackPanel>
                                                        <ProgressBar Value="{Binding DiskUsage}" Maximum="100" Height="10" Margin="30,10,0,0" Foreground="{Binding DiskUsage, Converter={StaticResource ValueToColorConverter}}" Background="#F2F2F7" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            
                                            <TextBlock Text="{Binding SystemHealthStatus}" FontSize="14" Margin="0,20,0,0" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 优化工具卡片 -->
                                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,20" Padding="20" Visibility="{Binding SelectedNavItem, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Tools}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                                                <TextBlock Text="🛠️" FontSize="24" />
                                                <TextBlock Text="优化工具" FontSize="18" FontWeight="Bold" Margin="10,0,0,0" />
                                            </StackPanel>
                                            
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="150" />
                                                    <RowDefinition Height="150" />
                                                </Grid.RowDefinitions>
                                                
                                                <!-- 缓存清理 -->
                                                <Border Grid.Row="0" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,10,10" Padding="15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                            <TextBlock Text="🧹" FontSize="20" />
                                                            <TextBlock Text="缓存清理" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" />
                                                        </StackPanel>
                                                        <TextBlock Text="清理系统和应用缓存，释放磁盘空间" FontSize="12" Foreground="#666666" Margin="30,10,0,0" />
                                                        <Button Content="立即清理" Command="{Binding CleanCacheCommand}" Width="100" Height="32" Margin="30,20,0,0" />
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- 系统优化 -->
                                                <Border Grid.Row="0" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="10,0,0,10" Padding="15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                            <TextBlock Text="⚡" FontSize="20" />
                                                            <TextBlock Text="系统优化" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" />
                                                        </StackPanel>
                                                        <TextBlock Text="优化启动项和服务，提升系统速度" FontSize="12" Foreground="#666666" Margin="30,10,0,0" />
                                                        <Button Content="立即优化" Command="{Binding OptimizeSystemCommand}" Width="100" Height="32" Margin="30,20,0,0" />
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- 软件卸载 -->
                                                <Border Grid.Row="1" Grid.Column="0" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,10,10,0" Padding="15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                            <TextBlock Text="🗑️" FontSize="20" />
                                                            <TextBlock Text="软件卸载" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" />
                                                        </StackPanel>
                                                        <TextBlock Text="卸载不需要的软件，释放系统资源" FontSize="12" Foreground="#666666" Margin="30,10,0,0" />
                                                        <Button Content="查看软件" Command="{Binding ShowUninstallCommand}" Width="100" Height="32" Margin="30,20,0,0" />
                                                    </StackPanel>
                                                </Border>
                                                
                                                <!-- 内存释放 -->
                                                <Border Grid.Row="1" Grid.Column="1" BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="10,10,0,0" Padding="15">
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                                            <TextBlock Text="💾" FontSize="20" />
                                                            <TextBlock Text="内存释放" FontSize="14" FontWeight="SemiBold" Margin="10,0,0,0" />
                                                        </StackPanel>
                                                        <TextBlock Text="释放未使用的内存，提升系统响应速度" FontSize="12" Foreground="#666666" Margin="30,10,0,0" />
                                                        <Button Content="立即释放" Command="{Binding FreeMemoryCommand}" Width="100" Height="32" Margin="30,20,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- AI分析卡片 -->
                                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,20" Padding="20" Visibility="{Binding SelectedNavItem, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=AI}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                                                <TextBlock Text="🧠" FontSize="24" />
                                                <TextBlock Text="AI分析" FontSize="18" FontWeight="Bold" Margin="10,0,0,0" />
                                            </StackPanel>
                                            
                                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Background="#F8F9FA" Margin="0,0,0,20" Padding="15">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding AIAnalysisStatus}" FontSize="14" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                        <TextBlock Text="●" FontSize="8" Foreground="#0078D7" />
                                                        <TextBlock Text="检查系统性能" FontSize="12" Margin="5,0,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <TextBlock Text="●" FontSize="8" Foreground="#0078D7" />
                                                        <TextBlock Text="分析内存使用" FontSize="12" Margin="5,0,0,0" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                                        <TextBlock Text="●" FontSize="8" Foreground="#0078D7" />
                                                        <TextBlock Text="评估磁盘空间" FontSize="12" Margin="5,0,0,0" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            
                                            <TextBlock Text="AI 建议" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            
                                            <ScrollViewer Height="400" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding Recommendations}" Margin="0,0,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Margin="0,0,0,10" Padding="15">
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="{Binding Action}" FontWeight="SemiBold" FontSize="14" />
                                                                        <TextBlock Text="{Binding Risk}" FontSize="12" Foreground="#666666" Margin="10,0,0,0" />
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Reason}" FontSize="12" Foreground="#666666" Margin="0,5,0,0" />
                                                                    <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                                                        <Button Content="一键执行" Command="{Binding DataContext.AcceptSuggestionCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}" CommandParameter="{Binding}" Width="100" Height="32" Margin="0,0,10,0" Background="#0078D7" Foreground="White" BorderThickness="0" />
                                                                        <Button Content="忽略" Command="{Binding DataContext.DismissSuggestionCommand, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}" CommandParameter="{Binding}" Width="80" Height="32" Background="#F2F2F7" Foreground="#333333" BorderThickness="0" />
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 操作历史卡片 -->
                                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,20" Padding="20" Visibility="{Binding SelectedNavItem, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=History}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                                                <TextBlock Text="📋" FontSize="24" />
                                                <TextBlock Text="操作历史" FontSize="18" FontWeight="Bold" Margin="10,0,0,0" />
                                            </StackPanel>
                                            
                                            <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" ItemsSource="{Binding OperationHistory}">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="时间" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="150" />
                                                    <DataGridTextColumn Header="操作" Binding="{Binding Operation}" Width="*" />
                                                    <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100" />
                                                    <DataGridTextColumn Header="详情" Binding="{Binding Details}" Width="200" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- 设置卡片 -->
                                    <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Background="White" Margin="0,0,0,20" Padding="20" Visibility="{Binding SelectedNavItem, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=Settings}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,20">
                                                <TextBlock Text="⚙️" FontSize="24" />
                                                <TextBlock Text="设置" FontSize="18" FontWeight="Bold" Margin="10,0,0,0" />
                                            </StackPanel>
                                            
                                            <TextBlock Text="应用设置" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10" />
                                            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,15">
                                                <StackPanel>
                                                    <TextBlock Text="AI 模型设置" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                    <StackPanel Margin="0,0,0,10">
                                                        <TextBlock Text="Ollama API 地址:" FontSize="12" Margin="0,0,0,5" />
                                                        <TextBox Text="{Binding OllamaApiUrl, UpdateSourceTrigger=PropertyChanged}" FontSize="12" Padding="5" BorderBrush="#E0E0E0" BorderThickness="1" />
                                                    </StackPanel>
                                                    <StackPanel Margin="0,0,0,10">
                                                        <TextBlock Text="默认模型:" FontSize="12" Margin="0,0,0,5" />
                                                        <StackPanel Orientation="Horizontal">
                                                            <ComboBox ItemsSource="{Binding AvailableModels}" SelectedItem="{Binding DefaultModel}" FontSize="12" Padding="5" BorderBrush="#E0E0E0" BorderThickness="1" Width="200" />
                                                            <Button Content="刷新" Command="{Binding RefreshModelsCommand}" Width="60" Height="28" Margin="10,0,0,0" FontSize="12" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <TextBlock Text="系统设置" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,10" />
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <CheckBox IsChecked="{Binding AutoSystemAnalysis}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                        <TextBlock Text="自动系统分析" FontSize="12" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                                        <CheckBox IsChecked="{Binding OptimizationNotification}" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                        <TextBlock Text="优化建议通知" FontSize="12" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                            
                                            <Button Content="保存设置" Command="{Binding SaveSettingsCommand}" Width="100" Height="32" Background="#0078D7" Foreground="White" BorderThickness="0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>